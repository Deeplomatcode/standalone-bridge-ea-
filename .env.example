# =============================================================================
# Standalone Bridge EA — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All values below are demo-account defaults.
#
# Usage:
#   export $(grep -v '^#' .env | xargs)   # bash/zsh
#   python python/run.py
# =============================================================================


# -----------------------------------------------------------------------------
# Symbols
# Comma-separated broker symbol names — must match exactly what MT4 shows.
# Demo brokers often append 'm' (e.g. EURUSDm). Check your Market Watch.
# -----------------------------------------------------------------------------
SYMBOLS=EURUSDm,XAUUSDm

# -----------------------------------------------------------------------------
# Timeframe
# Matches the chart timeframe the EA is attached to.
# Options: M1 M5 M15 M30 H1 H4 D1
# -----------------------------------------------------------------------------
TIMEFRAME=H1

# -----------------------------------------------------------------------------
# Bridge folders
# Must match the EA's BridgeFolder and FeedbackFolder input parameters.
# Use absolute paths when MT4 and Python run in different working directories.
#
# Example (macOS/shared Dropbox):
#   BRIDGE_FOLDER=/Users/yourname/Dropbox/bridge/outgoing
#   FEEDBACK_FOLDER=/Users/yourname/Dropbox/bridge/incoming
#
# Example (same machine, relative to python/ folder):
#   BRIDGE_FOLDER=bridge/outgoing
#   FEEDBACK_FOLDER=bridge/incoming
# -----------------------------------------------------------------------------
BRIDGE_FOLDER=bridge/outgoing
FEEDBACK_FOLDER=bridge/incoming

# -----------------------------------------------------------------------------
# Data directory — where OHLCV CSV files are cached
# -----------------------------------------------------------------------------
DATA_DIR=data/csv

# -----------------------------------------------------------------------------
# Orchestrator timing
# POLL_INTERVAL : seconds between each full cycle (60 = check every minute)
# LOOKBACK_DAYS : bars of history to load (30 days on H1 ≈ 480 bars)
# FEEDBACK_TIMEOUT : seconds to wait for EA feedback before logging a warning
# -----------------------------------------------------------------------------
POLL_INTERVAL=60
LOOKBACK_DAYS=30
FEEDBACK_TIMEOUT=90

# -----------------------------------------------------------------------------
# Risk parameters
# ACCOUNT_EQUITY    : your demo account balance in USD
# RISK_PCT_PER_TRADE: % of equity risked per trade (1.0 = 1%)
# CONTRACT_SIZE     : units per lot — 100000 for FX, 100 for XAUUSD
# MAX_OPEN_TRADES   : hard cap on concurrent positions
# MAX_LOT_PER_SYMBOL: max lots allowed on any single symbol
# MAX_LOT_TOTAL     : max total lots across all symbols
# MAX_DRAWDOWN_PCT  : kill-switch drawdown threshold (% of equity)
# -----------------------------------------------------------------------------
ACCOUNT_EQUITY=10000
RISK_PCT_PER_TRADE=1.0
CONTRACT_SIZE=100000
MAX_OPEN_TRADES=5
MAX_LOT_PER_SYMBOL=0.10
MAX_LOT_TOTAL=0.50
MAX_DRAWDOWN_PCT=10.0

# -----------------------------------------------------------------------------
# Strategy
# LOT_SIZE          : fallback fixed lot size (used only if lot sizer is off)
# SL_BUFFER         : extra distance beyond OB edge for SL (price units)
# RR_RATIO          : take-profit multiple of risk (2.0 = 2:1 R:R)
# ADX_TREND_THRESHOLD: ADX level above which market is considered trending
# -----------------------------------------------------------------------------
LOT_SIZE=0.01
SL_BUFFER=0.0002
RR_RATIO=2.0
ADX_TREND_THRESHOLD=25.0

# -----------------------------------------------------------------------------
# Session filter
# Restricts signals to London Open (07:00-10:00 UTC) and NY AM (13:00-16:00 UTC)
# Set to false to allow signals at any time (useful for testing)
# -----------------------------------------------------------------------------
SESSION_FILTER_ENABLED=true

# -----------------------------------------------------------------------------
# Logging
# LOG_LEVEL : DEBUG | INFO | WARNING | ERROR
# LOG_FILE  : path to log file (relative to python/ directory)
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/trading.log
